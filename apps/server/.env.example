# WebSocket server port
# Default: 8081
WS_PORT=8081

# Interval for broadcasting game state to overlay, in milliseconds
# Default: 1000
GAME_STATE_INTERVAL_MS=1000

# WebSocket ping/pong heartbeat interval in milliseconds (recommended: 10000-30000)
# Default: 30000
WS_HEARTBEAT_INTERVAL_MS=30000

# Use mock game state data by default.
# true  = use mock data
# false = use Riot Live Client API
USE_MOCK=true

# Allow insecure local TLS for Riot Live Client API.
# Riot Live Client API may use a local certificate that Node.js rejects.
# Enable only for local development when USE_MOCK=false.
ALLOW_INSECURE_LOCAL_TLS=false

# HTTP port for receiving Player Agent objective events
# Default: 3001
AGENT_INGEST_PORT=3001

# HTTP server port for /game-state endpoint (temporary, for debugging)
# Default: 3000
HTTP_PORT=3000
